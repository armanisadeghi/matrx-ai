# ── Application ───────────────────────────────────────────────────────────────
# TODO: Set to your service name
APP_NAME="Matrx Service"
APP_VERSION="0.1.0"
DEBUG=false
ENVIRONMENT=development

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=1

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (production only).
# In development/local/dev environments, all origins are allowed automatically.
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# ── Streaming ─────────────────────────────────────────────────────────────────
STREAM_CHUNK_SIZE=1024
STREAM_KEEPALIVE_INTERVAL=15.0

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# JWT secret for validating Supabase-issued user tokens.
# Found in: Supabase dashboard → Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=

# ── Admin Auth ────────────────────────────────────────────────────────────────
# Static admin token for internal service-to-service calls and dev tooling.
# Generate with: openssl rand -hex 32
ADMIN_API_TOKEN=
ADMIN_USER_ID=

# ── Sentry ────────────────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_PROFILES_SAMPLE_RATE=1.0

# ── Service URLs (for ServiceClient.for_service()) ────────────────────────────
# Add one entry per upstream Matrx service this service calls.
# Pattern: {SERVICE_NAME_UPPER}_URL
# MATRX_AI_URL=http://matrx-ai:8000
# MATRX_MEDIA_URL=http://matrx-media:8001
